# --- Public bucket (browser fetches S3 HTTPS directly; needs CORS + public read) ---
# NEXT_PUBLIC_DATA_LAKE_BASE_URL=https://YOUR_BUCKET.s3.REGION.amazonaws.com/becker/data/polymarket

# --- Private bucket (recommended): browser calls your Next API; server uses AWS keys ---
# NEXT_PUBLIC_DATA_LAKE_USE_S3_PROXY=true
# DATA_LAKE_S3_BUCKET=becker
# DATA_LAKE_S3_KEY_PREFIX=becker/data/polymarket
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# --- Athena (server-side lake SQL; see docs/SERVER_LAKE_ATHENA.md) ---
# `npm run athena:smoke` loads .env then .env.local (local overrides); shell env wins if set.
# Required for scripts/athena-smoke-test.js and future API routes:
# DATA_LAKE_ATHENA_OUTPUT_S3_URI=s3://YOUR_RESULTS_BUCKET/your-prefix/
# Optional:
# DATA_LAKE_ATHENA_WORKGROUP=primary
# DATA_LAKE_ATHENA_CATALOG=AwsDataCatalog
# DATA_LAKE_ATHENA_DATABASE=your_glue_database
# If Kalshi tables are in a different Glue database than Polymarket:
# DATA_LAKE_ATHENA_DATABASE_KALSHI=your_kalshi_database
# DATA_LAKE_ATHENA_SMOKE_SQL=SELECT * FROM your_table LIMIT 5
# Optional: Kalshi `blocks` crawler table if not using default mapping (see athenaTableMap.js)
# DATA_LAKE_ATHENA_TABLE_KALSHI_BLOCKS=blocks_xxxxxxxx
# Optional: max wait for Athena (ms) for /api/data-lake/athena-query
# DATA_LAKE_ATHENA_MAX_WAIT_MS=45000

NEXT_PUBLIC_DATA_LAKE_BASE_URL=
NEXT_PUBLIC_DATA_LAKE_USE_S3_PROXY=