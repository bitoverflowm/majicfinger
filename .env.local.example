# --- Public bucket (browser fetches S3 HTTPS directly; needs CORS + public read) ---
# NEXT_PUBLIC_DATA_LAKE_BASE_URL=https://YOUR_BUCKET.s3.REGION.amazonaws.com/becker/data/polymarket

# --- Private bucket (recommended): browser calls your Next API; server uses AWS keys ---
# NEXT_PUBLIC_DATA_LAKE_USE_S3_PROXY=true
# DATA_LAKE_S3_BUCKET=becker
# DATA_LAKE_S3_KEY_PREFIX=becker/data/polymarket
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

NEXT_PUBLIC_DATA_LAKE_BASE_URL=
NEXT_PUBLIC_DATA_LAKE_USE_S3_PROXY=
